# IntentLoop + Zene environment template
# Copy to .env and fill your real credentials.

# ----- Global defaults (used by all roles unless role-level override is set) -----
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=
# Optional
# LLM_BASE_URL=
# LLM_REGION=

# ----- Planner role override (optional) -----
# ZENE_PLANNER_PROVIDER=openai
# ZENE_PLANNER_MODEL=gpt-4o-mini
# ZENE_PLANNER_API_KEY=
# ZENE_PLANNER_BASE_URL=
# ZENE_PLANNER_REGION=

# ----- Executor role override (optional) -----
# ZENE_EXECUTOR_PROVIDER=openai
# ZENE_EXECUTOR_MODEL=gpt-4o
# ZENE_EXECUTOR_API_KEY=
# ZENE_EXECUTOR_BASE_URL=
# ZENE_EXECUTOR_REGION=

# ----- Reflector role override (optional) -----
# ZENE_REFLECTOR_PROVIDER=openai
# ZENE_REFLECTOR_MODEL=gpt-4o-mini
# ZENE_REFLECTOR_API_KEY=
# ZENE_REFLECTOR_BASE_URL=
# ZENE_REFLECTOR_REGION=

# ----- Zene runtime options (optional) -----
# ZENE_SIMPLE_MODE=false
# ZENE_USE_SEMANTIC_MEMORY=false

# ----- Observability (optional) -----
# ZENE_XTRACE_ENDPOINT=
# ZENE_XTRACE_TOKEN=
